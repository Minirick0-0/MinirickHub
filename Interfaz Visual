        -- Crear Slider
        function Tab:CreateSlider(config)
            config = config or {}
            local min = config.Min or 0
            local max = config.Max or 100
            local default = config.Default or min
            local increment = config.Increment or 1
            local value = default
            
            local slider = Instance.new("Frame")
            slider.Name = "Slider"
            slider.Size = UDim2.new(1, 0, 0, 55)
            slider.BackgroundColor3 = Library.Theme.Element
            slider.BorderSizePixel = 0
            slider.Parent = tabContent
            makeRound(slider, 8)
            
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.65, 0, 0, 22)
            label.Position = UDim2.fromOffset(12, 8)
            label.BackgroundTransparency = 1
            label.Text = config.Name or "Slider"
            label.TextColor3 = Library.Theme.Text
            label.Font = Enum.Font.GothamSemibold
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = slider
            
            local valueLabel = Instance.new("TextLabel")
            valueLabel.Size = UDim2.new(0.35, -12, 0, 22)
            valueLabel.Position = UDim2.new(0.65, 0, 0, 8)
            valueLabel.BackgroundTransparency = 1
            valueLabel.Text = tostring(value)
            valueLabel.TextColor3 = Library.Theme.Accent
            valueLabel.Font = Enum.Font.GothamBold
            valueLabel.TextSize = 13
            valueLabel.TextXAlignment = Enum.TextXAlignment.Right
            valueLabel.Parent = slider
            
            local track = Instance.new("Frame")
            track.Size = UDim2.new(1, -24, 0, 5)
            track.Position = UDim2.fromOffset(12, 38)
            track.BackgroundColor3 = Library.Theme.Border
            track.BorderSizePixel = 0
            track.Parent = slider
            makeRound(track, 3)
            
            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            fill.BackgroundColor3 = Library.Theme.Accent
            fill.BorderSizePixel = 0
            fill.Parent = track
            makeRound(fill, 3)
            
            local thumb = Instance.new("Frame")
            thumb.Size = UDim2.fromOffset(16, 16)
            thumb.Position = UDim2.new((value - min) / (max - min), -8, 0.5, -8)
            thumb.BackgroundColor3 = Color3.new(1, 1, 1)
            thumb.BorderSizePixel = 0
            thumb.Parent = track
            makeRound(thumb, 8)
            addStroke(thumb, Library.Theme.Accent, 3)
            
            local dragging = false
            
            thumb.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    value = math.floor((min + (max - min) * pos) / increment + 0.5) * increment
                    value = math.clamp(value, min, max)
                    
                    valueLabel.Text = tostring(value)
                    tween(fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.05)
                    tween(thumb, {Position = UDim2.new(pos, -8, 0.5, -8)}, 0.05)
                    
                    if config.Callback then
                        config.Callback(value)
                    end
                end
            end)
            
            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    value = math.floor((min + (max - min) * pos) / increment + 0.5) * increment
                    value = math.clamp(value, min, max)
                    
                    valueLabel.Text = tostring(value)
                    tween(fill, {Size = UDim2.new(pos, 0, 1, 0)})
                    tween(thumb, {Position = UDim2.new(pos, -8, 0.5, -8)})
                    
                    if config.Callback then
                        config.Callback(value)
                    end
                end
            end)
            
            return slider
        end
        
        -- Crear Dropdown
        function Tab:CreateDropdown(config)
            config = config or {}
            local options = config.Options or {"Option 1", "Option 2"}
            local selected = config.Default or options[1]
            local open = false
            
            local dropdown = Instance.new("Frame")
            dropdown.Name = "Dropdown"
            dropdown.Size = UDim2.new(1, 0, 0, 40)
            dropdown.BackgroundColor3 = Library.Theme.Element
            dropdown.BorderSizePixel = 0
            dropdown.ClipsDescendants = true
            dropdown.Parent = tabContent
            makeRound(dropdown, 8)
            
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.4, 0, 0, 40)
            label.Position = UDim2.fromOffset(12, 0)
            label.BackgroundTransparency = 1
            label.Text = config.Name or "Dropdown"
            label.TextColor3 = Library.Theme.Text
            label.Font = Enum.Font.GothamSemibold
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = dropdown
            
            local selectBtn = Instance.new("TextButton")
            selectBtn.Size = UDim2.new(0.6, -24, 0, 30)
            selectBtn.Position = UDim2.new(0.4, 6, 0, 5)
            selectBtn.BackgroundColor3 = Library.Theme.Background
            selectBtn.Text = "  " .. selected
            selectBtn.TextColor3 = Library.Theme.Text
            selectBtn.Font = Enum.Font.Gotham
            selectBtn.TextSize = 12
            selectBtn.TextXAlignment = Enum.TextXAlignment.Left
            selectBtn.AutoButtonColor = false
            selectBtn.Parent = dropdown
            makeRound(selectBtn, 6)
            
            local arrow = Instance.new("TextLabel")
            arrow.Size = UDim2.fromOffset(25, 30)
            arrow.Position = UDim2.new(1, -28, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.Text = "▼"
            arrow.TextColor3 = Library.Theme.TextDark
            arrow.Font = Enum.Font.Gotham
            arrow.TextSize = 10
            arrow.Parent = selectBtn
            
            local optionsList = Instance.new("Frame")
            optionsList.Size = UDim2.new(1, -12, 0, 0)
            optionsList.Position = UDim2.fromOffset(6, 45)
            optionsList.BackgroundTransparency = 1
            optionsList.Parent = dropdown
            
            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Padding = UDim.new(0, 3)
            listLayout.Parent = optionsList
            
            for _, option in ipairs(options) do
                local optBtn = Instance.new("TextButton")
                optBtn.Size = UDim2.new(1, 0, 0, 30)
                optBtn.BackgroundColor3 = Library.Theme.Background
                optBtn.Text = "  " .. option
                optBtn.TextColor3 = Library.Theme.Text
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextSize = 12
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                optBtn.AutoButtonColor = false
                optBtn.Parent = optionsList
                makeRound(optBtn, 6)
                
                optBtn.MouseButton1Click:Connect(function()
                    selected = option
                    selectBtn.Text = "  " .. option
                    open = false
                    tween(dropdown, {Size = UDim2.new(1, 0, 0, 40)})
                    tween(arrow, {Rotation = 0})
                    if config.Callback then
                        config.Callback(option)
                    end
                end)
                
                optBtn.MouseEnter:Connect(function()
                    tween(optBtn, {BackgroundColor3 = Library.Theme.ElementHover})
                end)
                
                optBtn.MouseLeave:Connect(function()
                    tween(optBtn, {BackgroundColor3 = Library.Theme.Background})
                end)
            end
            
            selectBtn.MouseButton1Click:Connect(function()
                open = not open
                local height = open and (45 + #options * 33) or 40
                tween(dropdown, {Size = UDim2.new(1, 0, 0, height)})
                tween(arrow, {Rotation = open and 180 or 0})
            end)
            
            return dropdown
        end
        
