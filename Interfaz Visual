--[[
MinirickUI – UI Base Estilo Carmesí para Xeno
Autor: Minirick
Versión: 0.2

- Bordes redondeados
- Colores carmesí/marrón
- TopBar con logo M de agua (simulado)
- Sidebar con iconos
- Compatible Xeno / gethui()
- Animaciones TweenService
]]

-- =========================
-- Servicios
-- =========================
local TweenService = game:GetService("TweenService")

-- =========================
-- Parent Xeno
-- =========================
local function getParent()
    if gethui then return gethui() end
    return game.CoreGui
end

-- =========================
-- Theme Carmesí
-- =========================
local Theme = {
    Background = Color3.fromRGB(58,31,31),       -- Marrón oscuro TopBar
    Sidebar = Color3.fromRGB(92,46,46),         -- Marrón medio Sidebar
    Panel = Color3.fromRGB(122,59,59),          -- Marrón claro Botones
    Text = Color3.fromRGB(245,245,245),         -- Blanco
    Accent = Color3.fromRGB(211,31,31),         -- Rojo intenso
    Radius = 12,
    TweenTime = 0.18,
    Font = Enum.Font.Gotham
}

-- =========================
-- Utils Tween
-- =========================
local function Tween(obj, props)
    TweenService:Create(obj, TweenInfo.new(Theme.TweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

-- =========================
-- Section
-- =========================
local Section = {}
Section.__index = Section

function Section.new(parent, name, icon)
    local self = setmetatable({}, Section)
    self.Open = false

    -- Botón sección
    local button = Instance.new("TextButton")
    button.Size = UDim2.fromOffset(150, 36)
    button.BackgroundColor3 = Theme.Sidebar
    button.Text = " " .. name
    button.TextColor3 = Theme.Text
    button.Font = Theme.Font
    button.TextSize = 14
    button.BorderSizePixel = 0
    button.AutoButtonColor = false
    button.Parent = parent

    -- Icono (simulado con texto o puedes usar ImageLabel)
    if icon then
        button.Text = icon .. " " .. name
    end

    Instance.new("UICorner", button).CornerRadius = UDim.new(0, Theme.Radius)

    -- Contenedor desplegable
    local container = Instance.new("Frame")
    container.Size = UDim2.fromOffset(150,0)
    container.BackgroundTransparency = 1
    container.ClipsDescendants = true
    container.Parent = parent

    local layout = Instance.new("UIListLayout", container)
    layout.Padding = UDim.new(0,6)

    button.MouseButton1Click:Connect(function()
        self.Open = not self.Open
        Tween(container, {Size = self.Open and UDim2.fromOffset(150,120) or UDim2.fromOffset(150,0)})
    end)

    self.Container = container
    return self
end

function Section:AddButton(config)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(140,28)
    btn.BackgroundColor3 = Theme.Panel
    btn.Text = config.Name or "Button"
    btn.TextColor3 = Theme.Text
    btn.Font = Theme.Font
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.Parent = self.Container

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, Theme.Radius)

    btn.MouseButton1Click:Connect(function()
        if config.Callback then config.Callback() end
    end)
end

-- =========================
-- UI Root
-- =========================
local UI = {}
UI.__index = UI

function UI:CreateWindow(config)
    local self = setmetatable({}, UI)

    local gui = Instance.new("ScreenGui")
    gui.Name = "MinirickHubUI"
    gui.ResetOnSpawn = false
    gui.Parent = getParent()

    -- Main Frame
    local main = Instance.new("Frame")
    main.Size = UDim2.fromOffset(640,440)
    main.Position = UDim2.fromScale(0.5,0.5)
    main.AnchorPoint = Vector2.new(0.5,0.5)
    main.BackgroundColor3 = Theme.Background
    main.BorderSizePixel = 0
    main.Parent = gui

    Instance.new("UICorner", main).CornerRadius = UDim.new(0,Theme.Radius)

    -- TopBar
    local topBar = Instance.new("Frame")
    topBar.Size = UDim2.new(1,0,0,40)
    topBar.BackgroundColor3 = Theme.Background
    topBar.BorderSizePixel = 0
    topBar.Parent = main
    Instance.new("UICorner", topBar).CornerRadius = UDim.new(0,Theme.Radius)

    local title = Instance.new("TextLabel")
    title.Text = "MinirickHub"
    title.TextColor3 = Theme.Text
    title.Font = Theme.Font
    title.TextSize = 18
    title.BackgroundTransparency = 1
    title.Position = UDim2.fromOffset(50,5)
    title.Size = UDim2.new(0,200,1,0)
    title.Parent = topBar

    -- Logo simulado (ImageLabel o TextLabel)
    local logo = Instance.new("TextLabel")
    logo.Text = "M"
    logo.TextColor3 = Theme.Accent
    logo.Font = Theme.Font
    logo.TextSize = 20
    logo.BackgroundTransparency = 1
    logo.Position = UDim2.fromOffset(10,5)
    logo.Size = UDim2.new(0,30,1,0)
    logo.Parent = topBar

    -- Sidebar
    local sidebar = Instance.new("Frame")
    sidebar.Size = UDim2.fromOffset(160,main.Size.Y.Offset-40)
    sidebar.Position = UDim2.fromOffset(0,40)
    sidebar.BackgroundColor3 = Theme.Sidebar
    sidebar.BorderSizePixel = 0
    sidebar.Parent = main
    local layout = Instance.new("UIListLayout", sidebar)
    layout.Padding = UDim.new(0,6)

    self.Sidebar = sidebar
    return self
end

function UI:AddSection(config)
    return Section.new(self.Sidebar, config.Name or "Section", config.Icon)
end

return UI
